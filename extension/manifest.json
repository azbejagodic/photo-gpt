{
  "manifest_version": 3,
  "name": "SnapOverLAN",
  "version": "1.0.2",
  "description": "Fetch images from SnapOverLAN and copy image blobs to clipboard from the popup user gesture.",
  "action": {
    "default_title": "SnapOverLAN",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*"
  ],
  "optional_permissions": [
    "clipboardRead"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
