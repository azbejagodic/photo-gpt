{
  "manifest_version": 3,
  "name": "Photo To GPT",
  "version": "1.0.2",
  "description": "Fetch images from a LAN server and copy image blobs to clipboard from the popup user gesture.",
  "action": {
    "default_title": "LAN Image Clipboard Copier",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "optional_permissions": [
    "clipboardRead"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
