{
  "manifest_version": 3,
  "name": "SnapOverLAN",
  "version": "1.0.3",
  "description": "Fetch images from SnapOverLAN and copy image blobs to clipboard from the popup user gesture.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "SnapOverLAN",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "19": "icons/icon-19.png",
      "20": "icons/icon-20.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png",
      "38": "icons/icon-38.png"
    }
  },
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*"
  ],
  "optional_permissions": [
    "clipboardRead"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
