{
  "name": "snap-over-lan",
  "version": "1.0.0",
  "description": "Local LAN media transfer bridge between phone and PC",
  "type": "module",
  "main": "app/main.js",
  "scripts": {
    "start": "electron app/main.js",
    "server": "node app/server/index.js",
    "desktop": "electron app/main.js",
    "app": "electron app/main.js",
    "dist": "npm run generate:icons && electron-builder --win",
    "generate:icons": "node scripts/generate-icons.mjs",
    "test:pwa-connection": "node --test tests/pwa-connection.test.mjs",
    "test:electron-controls": "node --test tests/electron-server-controls.test.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "local.snapoverlan.app",
    "productName": "SnapOverLAN",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "assets/electron"
    },
    "files": [
      "app/**/*",
      "pwa/**/*",
      "extension/**/*",
      "assets/**/*",
      "package.json",
      "!data/**/*",
      "!dist/**/*",
      "!node_modules/.cache/**/*",
      "!**/*.log"
    ],
    "win": {
      "icon": "assets/electron/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/electron/app.icns"
    },
    "linux": {
      "icon": "assets/electron"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SnapOverLAN",
      "include": "build/installer.nsh",
      "artifactName": "${productName} Setup ${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    }
  }
}
